NEXT_PUBLIC_SITE_URL=https://virgo.cl
NEXT_PUBLIC_WHATSAPP_NUMBER=56900000000

# Kommo CRM — subdominio del workspace, incluyendo https://
KOMMO_BASE_URL=https://virgocorredores.kommo.com
# Long-lived integration token (Kommo → Ajustes → Integraciones → crear integración privada)
KOMMO_ACCESS_TOKEN=
# IDs numéricos del embudo / etapa donde entran los leads nuevos
KOMMO_PIPELINE_ID=
KOMMO_STATUS_ID=
# Usuario Kommo al que se asigna el lead (opcional; si no, queda sin asignar)
KOMMO_RESPONSIBLE_USER_ID=
# Campo custom tipo texto donde se guarda "virgo:<source>" (opcional)
KOMMO_LEAD_SOURCE_FIELD_ID=
# Timeout de la llamada a Kommo en ms (default 10000)
KOMMO_TIMEOUT_MS=

AUTH_SECRET=
