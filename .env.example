NEXT_PUBLIC_SITE_URL=https://virgo.cl
NEXT_PUBLIC_WHATSAPP_NUMBER=56900000000

# ────── Base de datos (Vercel Postgres / Neon) ──────
DATABASE_URL=

# ────── Auth.js ──────
# Genera uno: openssl rand -base64 32
AUTH_SECRET=

# ────── Bootstrap del primer admin ──────
# Secret arbitrario para autorizar POST /api/admin/bootstrap y /api/admin/migrate
ADMIN_BOOTSTRAP_SECRET=
# Datos del primer admin — se usan solo la primera vez
ADMIN_RUT=12.345.678-9
ADMIN_EMAIL=admin@virgo.cl
ADMIN_NOMBRE=Administrador Virgo
# Mínimo 10 caracteres. Borrar después del primer bootstrap.
ADMIN_INITIAL_PASSWORD=

# ────── Kommo CRM ──────
KOMMO_BASE_URL=https://virgocorredores.kommo.com
KOMMO_ACCESS_TOKEN=
KOMMO_PIPELINE_ID=
KOMMO_STATUS_ID=
KOMMO_RESPONSIBLE_USER_ID=
